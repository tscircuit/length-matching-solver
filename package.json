{
  "name": "@tscircuit/length-matching-solver",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "start": "cosmos",
    "build": "tsup lib/index.ts --format esm --dts --sourcemap",
