{
  "name": "@tscircuit/length-matching-solver",
  "version": "0.0.1",
  "type": "module",
  "main": "./lib/index.ts",
  "module": "./lib/index.ts",
  "types": "./lib/index.ts",
  "files": ["lib"],
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "import": "./lib/index.ts"
    }
  },
  "scripts": {
    "start": "cosmos",
    "build": "tsup lib/index.ts --format esm --dts --sourcemap",
    "test": "bun test --timeout 9999999",
    "typecheck": "tsc --noEmit",
    "typecheck:structure": "bun run --parallel --no-exit-on-error typecheck:files typecheck:folders",
    "typecheck:files": "eslint .",
    "typecheck:folders": "lintp || echo '::warning title=Folder structure advisory::One or more folders contain over 10 TypeScript files.'",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "cosmos:export": "cosmos-export",
    "vercel-build": "cosmos-export"
  },
  "dependencies": {
    "@tscircuit/math-utils": "^0.0.36",
    "@tscircuit/solver-utils": "^0.0.16",
    "graphics-debug": "^0.0.96",
    "polished": "^4.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@typescript-eslint/parser": "8.65.0",
    "@types/bun": "^1.2.23",
    "@types/react": "18",
    "@types/react-dom": "18",
    "@vitejs/plugin-react": "4",
    "eslint": "10.7.0",
    "eslint-plugin-project-structure": "3.14.3",
    "lintp-cli": "0.8.1",
    "react": "18",
    "react-cosmos": "6.2.3",
    "react-cosmos-plugin-vite": "6.2.0",
    "react-dom": "18",
    "tsup": "^8.3.6",
    "typescript": "^5.9.3",
    "vite": "6",
    "vite-tsconfig-paths": "5"
  }
}
