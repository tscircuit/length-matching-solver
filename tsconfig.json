{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": [
    "lib/**/*.ts",
    "tests/**/*.ts",
    "fixtures/**/*.tsx",
    "main.tsx",
    "vite.config.ts"
  ]
}
